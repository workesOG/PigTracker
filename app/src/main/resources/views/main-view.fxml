<?xml version="1.0" encoding="UTF-8"?>

<!-- Af Theis Thomsen -->

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="662.0" prefWidth="1200.0" stylesheets="@../styles/app.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pigtracker.controller.MainController">
   <children>
      <TabPane prefHeight="800.0" prefWidth="1200.0" tabClosingPolicy="UNAVAILABLE" tabMinHeight="36.0" tabMinWidth="120.0">
        <tabs>
         <Tab text="Dashboard">
            <content>
              <fx:include source="dashboard-view.fxml" />
            </content>
         </Tab>
         <Tab text="Data">
            <content>
               <fx:include source="data-view.fxml" />
            </content>
         </Tab>
         <Tab text="Reports">
            <content>
              <fx:include source="reports-view.fxml" />
            </content>
         </Tab>
         <Tab text="Import &amp; Export">
            <content>
               <fx:include source="import-export-view.fxml" />
            </content>
         </Tab>
         </tabs>
      </TabPane>
      <Button mnemonicParsing="false" onAction="#handleLogout" prefHeight="32.0" prefWidth="100.0" styleClass="logout-button" text="Log Out" AnchorPane.rightAnchor="5.0" AnchorPane.topAnchor="5.0" />

   </children>
</AnchorPane>
