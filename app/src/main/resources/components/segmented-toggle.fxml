<?xml version="1.0" encoding="UTF-8"?>

<!-- Af Theis Thomsen -->

<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="30.0" prefWidth="450.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pigtracker.controller.components.SegmentedToggleController">
   <children>
      <HBox fx:id="container" prefHeight="30.0" prefWidth="450.0" stylesheets="@../styles/app.css" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
              <ToggleButton style="-fx-pref-width: 150;" styleClass="segment-left" text="Left" />
              <ToggleButton selected="true" style="-fx-pref-width: 150;" styleClass="segment-middle" text="Middle" />
              <ToggleButton style="-fx-pref-width: 150;" styleClass="segment-right" text="Right" />
         </children>
      </HBox>
   </children>
</AnchorPane>
